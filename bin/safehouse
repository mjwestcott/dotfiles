    "profiles/55-integrations-optional/cloud-storage.sb")
      cat <<'__SAFEHOUSE_EMBEDDED_profiles_55_integrations_optional_cloud_storage_sb__'
;; ---------------------------------------------------------------------------
;; Integration: Cloud Storage
;; FileProvider XPC access for macOS cloud storage mounts (Google Drive,
;; Dropbox, iCloud Drive, OneDrive, and other FileProvider-based providers).
;; Source: 55-integrations-optional/cloud-storage.sb
;; ---------------------------------------------------------------------------

;; macOS cloud storage providers mount under ~/Library/CloudStorage via the
;; FileProvider framework.  Directory listing and file I/O on these paths is
;; routed through XPC to the com.apple.FileProvider service.  Without this
;; mach-lookup, sandbox file-read*/file-write* rules that cover CloudStorage
;; paths are insufficient — readdir() and open() return EPERM because the
;; underlying XPC call is blocked.
;;
;; com.apple.FileCoordination is included because FileProvider operations use
;; coordinated reads/writes under the hood; without it, concurrent access from
;; the provider extension and the sandboxed process can deadlock or fail.

(allow mach-lookup
    (global-name "com.apple.FileProvider")                                 ;; FileProvider XPC — routes I/O to cloud storage provider extensions.
    (global-name "com.apple.FileCoordination")                             ;; Coordinated I/O — required for safe concurrent access with provider extensions.
)
__SAFEHOUSE_EMBEDDED_profiles_55_integrations_optional_cloud_storage_sb__
      ;;
    "profiles/55-integrations-optional/docker.sb")
      cat <<'__SAFEHOUSE_EMBEDDED_profiles_55_integrations_optional_docker_sb__'
;; ---------------------------------------------------------------------------
;; Integration: Docker
;; Docker daemon socket access for container operations. High-risk.
;; Source: 55-integrations-optional/docker.sb
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (literal "/var/run/docker.sock")                                       ;; Standard Docker daemon socket path.
    (literal "/private/var/run/docker.sock")                               ;; macOS backing path for /var/run/docker.sock.
    (home-literal "/.docker/run/docker.sock")                              ;; Docker Desktop user-scoped socket path.
    (home-literal "/.orbstack/run/docker.sock")                            ;; OrbStack user-scoped daemon socket path.
    (home-subpath "/.docker")                                              ;; Docker CLI config, contexts, plugins, buildx state.
    (home-subpath "/.colima")                                              ;; Colima runtime state (VM, socket, and instance metadata).
    (home-literal "/.rd/docker.sock")                                      ;; Rancher Desktop socket.
)

;; Re-allow connect() on Docker unix sockets (matches the network-outbound deny
;; in container-runtime-default-deny.sb).
(allow network-outbound
    (remote unix-socket (path-literal "/var/run/docker.sock"))
    (remote unix-socket (path-literal "/private/var/run/docker.sock"))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.docker/run/docker\\.sock$")))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.orbstack/run/docker\\.sock$")))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.colima/docker\\.sock$")))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.colima/[^/]+/docker\\.sock$")))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.rd/docker\\.sock$")))
)

