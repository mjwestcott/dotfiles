    "profiles/50-integrations-core/ssh-agent-default-deny.sb")
      cat <<'__SAFEHOUSE_EMBEDDED_profiles_50_integrations_core_ssh_agent_default_deny_sb__'
;; ---------------------------------------------------------------------------
;; Integration: SSH Agent Default Deny
;; Default-deny SSH agent unix sockets; ssh integration can re-open later.
;; Source: 50-integrations-core/ssh-agent-default-deny.sb
;; ---------------------------------------------------------------------------

;; #safehouse-test-id:ssh-agent-socket-deny# Keep SSH agent credential use opt-in.
;; SSH clients use connect() on unix domain sockets, which sandbox-exec classifies
;; as network-outbound rather than file-read/write. Without this deny block,
;; open network policy in 20-network.sb allows agent-backed authentication even
;; when --enable=ssh is not set.
(deny network-outbound
    (remote unix-socket (path-regex #"^/private/tmp/com\.apple\.launchd\.[^/]+/Listeners$"))
    (remote unix-socket (path-regex #"^/tmp/com\.apple\.launchd\.[^/]+/Listeners$"))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.ssh/agent(/.*)?$")))
)
__SAFEHOUSE_EMBEDDED_profiles_50_integrations_core_ssh_agent_default_deny_sb__
      ;;
    "profiles/50-integrations-core/worktree-common-dir.sb")
      cat <<'__SAFEHOUSE_EMBEDDED_profiles_50_integrations_core_worktree_common_dir_sb__'
;; ---------------------------------------------------------------------------
;; Integration: Git Worktree Common Dir
;; Minimal support for running inside a linked Git worktree.
;; Source: 50-integrations-core/worktree-common-dir.sb
;; ---------------------------------------------------------------------------

;; Why this exists:
;; A linked Git worktree can keep refs, the index, and worktree bookkeeping
;; under a shared git common dir outside the selected workdir. Without access
;; to that shared metadata, normal git commands from the active worktree fail
;; even though the checkout itself is already writable.
;;
;; Limitations:
;; - Detection happens once when Safehouse launches the wrapped process.
;; - This only grants the active worktree's shared git common dir when the
;;   selected workdir itself resolves to a Git worktree root.
;; - Sibling worktree files are handled separately by the default `worktrees`
;;   integration and remain read-only.
;;
;; Runtime snapshot (this placeholder comment line is replaced at launch):
;;   shared git common dir: __SAFEHOUSE_REPLACE_ME_WITH_GIT_WORKTREE_COMMON_DIR_STATUS__
;;
;; Example generated rules (illustrative only; actual paths depend on launch):
;;   (allow file-read* file-write* (subpath "/Users/alice/src/project/.git"))
;;
;; Runtime-generated rules are emitted immediately below this profile section.
__SAFEHOUSE_EMBEDDED_profiles_50_integrations_core_worktree_common_dir_sb__
      ;;
    "profiles/50-integrations-core/worktrees.sb")
      cat <<'__SAFEHOUSE_EMBEDDED_profiles_50_integrations_core_worktrees_sb__'
;; ---------------------------------------------------------------------------
;; Integration: Worktrees
;; Launch-time snapshot of sibling Git worktree paths for cross-worktree read access.
;; Source: 50-integrations-core/worktrees.sb
;; ---------------------------------------------------------------------------

;; Why this exists:
;; Multi-worktree flows often involve inspecting diffs, review branches, or
;; alternative implementations across sibling worktrees in the same repository.
;; Safehouse grants that visibility by default so agents can compare work
;; across existing worktrees without manual path flags.
;;
;; Limitations:
;; - The snapshot is computed once when Safehouse launches the wrapped process.
;; - New worktrees created after launch are NOT added to the running sandbox.
;; - Sibling worktrees stay read-only by default; use --add-dirs when you
;;   intentionally want broader write access to a stable worktree parent.
;;
;; Runtime snapshot (this placeholder comment line is replaced at launch):
;;   linked worktree read paths: __SAFEHOUSE_REPLACE_ME_WITH_GIT_LINKED_WORKTREE_PATHS_STATUS__
;;
;; Example generated rules (illustrative only; actual paths depend on launch):
;;   (allow file-read* (subpath "/Users/alice/src/project-review"))
;;   (allow file-read* (subpath "/Users/alice/src/project-fixup"))
;;
;; Runtime-generated rules are emitted immediately below this profile section.
__SAFEHOUSE_EMBEDDED_profiles_50_integrations_core_worktrees_sb__
      ;;
    "profiles/55-integrations-optional/1password.sb")
      cat <<'__SAFEHOUSE_EMBEDDED_profiles_55_integrations_optional_1password_sb__'
;; ---------------------------------------------------------------------------
;; Integration: 1Password
;; 1Password desktop app and CLI agent socket access.
;; Source: 55-integrations-optional/1password.sb
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-subpath "/.config/op")                               ;; 1Password CLI (op) config and session tokens.
    (home-subpath "/.1password")                               ;; 1Password SSH agent symlink dir (includes ~/.1password/agent.sock).
    (subpath "/Users/Shared/.1password")                       ;; Some installs use shared path for SSH agent socket.
    (regex (string-append "^" HOME_DIR "/Library/Group Containers/[A-Za-z0-9]+\\.com\\.1password/t/agent\\.sock$")) ;; 1Password SSH agent socket file (team prefix varies).
)

;; 1Password Desktop settings probe (read-only)
;; Newer op builds read settings.json here to detect Desktop integration state.
(allow file-read*
    (regex (string-append "^" HOME_DIR "/Library/Group Containers/[A-Za-z0-9]+\\.com\\.1password/Library/Application Support/1Password/Data/settings(/.*)?$"))      ;; Desktop settings dir (includes settings.json).
)

;; 1Password op binary reads are covered by system-runtime (/usr, /opt).

;; 1Password SSH agent config
(allow file-read*
    (home-subpath "/.config/1Password")  ;; ssh/agent.toml — controls which keys are offered.
)

(allow mach-lookup
    (global-name-regex #"^([A-Za-z0-9]+\.)?com\.1password(\..*)?$")  ;; 1Password app/service IPC endpoints (including team-prefixed browser-helper names).
    (global-name-regex #"^com\.agilebits(\..*)?$")                    ;; Legacy AgileBits service names still used by some installs.
)
